# Block PHP execution in the uploads directory
# WHY: If an attacker uploads a .php file, Apache will not execute it.
# NOTE: php_flag only works with mod_php (not FastCGI/CGI), which causes 500 errors on Laragon.
# Using FilesMatch instead for broad compatibility.
<FilesMatch "\.ph(?:p[3457]?|t|tml)$">
    Require all denied
</FilesMatch>
